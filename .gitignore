# Ignore binaries (all files without extension or .exe extension)
*
!*.*
*.exe
!*/
# Don't ignore binaries (scripts) under .githooks
!.githooks/*

# Ignore Slang generated shader files
*.glsl
*.spv

# Ignore RenderDoc files
*.cap

# Ignore binary replay, config and test files generated by the game unless they are saved under testData/
*.replay
*.bin
!testData/*.replay
!testData/*.bin

# Ignore Nimble generated files
nimble.paths
