import Sdf;

interface IFloatSdfScene {
	static float sdf(float3 p);
}
interface IDifferentiableFloatSdfScene {
	[Differentiable]
	static float sdf(float3 p);
}

struct SceneUniforms {
  float aspect;
  float3 camPos, camForward, camRight, camUp, hitColor, bgColor;
  float fov;
}

enum SdfInstructionKind {
	// Operations
	AddOp, SubOp, InterOp, XorOp, SmoothAddOp, SmoothSubOp, SmoothInterOp, 
	// Shapes
	Sphere, Box, RoundBox, BoxFrame, Cone, CappedCone, HexPrism, TriPrism, Capsule,
	CappedCylinder, RoundedCylinder, CutSphere, Octahedron, Pyramid, Triangle, Quad
}

struct Material {
	float3 color; // Add alpha channel for transparency and add refractive index?
	float metalness; // How reflective is the surface? Controls how much of diffuse/specular lighting the surface will have.
}

struct SdfProgramData {
	 Material materialData[256];
	 // This is enough for about 8000 shapes in the worst case, but it should be enough for most SDF scenes that can run in real-time
	 uint params[65536]; 
	 // Index to params where instruction outputs start. For implementing safety mechanisms together with isLeafNode.
	 // uint16_t instructionOutputsStart;
}

struct SdfInstruction {
	SdfInstructionKind kind;
	// Now that this is using packed values, kind could be packed into the first 16 bits of some packed uint
	uint paramsIndex;
	uint outputIndex;
	// First 16 bits paramsIndex: Index to array that has both the outputs of this SDF program and the input parameters
	// Next 16 bits outputIndex: Index to the program outputs array where this instruction will put its return value to
  uint materialIndex;
  uint paramsSize;
	// First 8 bits materialIndex: Index to the materialData array
	// Next 8 bits paramsSize: How many bytes starting from paramsIndex are parameters for this instruction (for debug purposes)
	// Last 16 bits are unused

	// This could be used to implement a safety mechanism that clearly shows if a non-leaf node is trying to read program input parameters.
	// Non-leaf nodes should only read results of previous instructions.
	// bool isLeafNode; 
}

enum RenderMode {
	ShadedScene, UnlitScene, DebugNormals, DebugStepCounts
}

struct DebugSettings {
	RenderMode mode;
}

[[vk::binding(0)]]
ConstantBuffer<SceneUniforms> scene;
[[vk::binding(1)]]
ConstantBuffer<DebugSettings> debugOpt;

[[vk::binding(0)]]
RWStructuredBuffer<SdfProgramData> sceneProgramData;
[[vk::binding(1)]]
RWStructuredBuffer<SdfInstruction> sceneProgram;

struct VertexInput {
  [[vk::location(0)]]
  float2 pos;
  [[vk::location(1)]]
  float2 uv;
}

struct VertexOutput {
  float4 pos : SV_Position;
  float2 fragUv;
}

struct FragmentOutput {
  float4 color : SV_Target0;
}


[shader("vertex")]
VertexOutput vertexMain(VertexInput input) {
  VertexOutput output;
  output.pos = float4(input.pos, 0.0, 1.0);
  output.fragUv = input.uv;
  return output;
}

// ChatGPT generated test scene
struct ChatgptSimpleScene : IFloatSdfScene {
	[Differentiable]
	static float sdf(float3 p) {
		// Shift scene down a bit
		p.y += 0.5;

		// Ground plane (big flat box)
		float dGround = sdBox(p + float3(0, 1.0, 0), float3(10.0, 0.5, 10.0));

		// Central sphere cluster
		float dSphere1 = sdSphere(p - float3(0, 0, -3), 1.0);
		float dSphere2 = sdSphere(p - float3(1.5, 0.2, -2.5), 0.6);
		float dSphere3 = sdSphere(p - float3(-1.5, -0.2, -2.5), 0.6);
		float dCluster = opUnion(dSphere1, opUnion(dSphere2, dSphere3));

		// Box tower with subtraction
		float dBoxBase = sdBox(p - float3(-3, 0.0, -4), float3(0.7, 1.2, 0.7));
		float dBoxHole = sdSphere(p - float3(-3, 0.0, -4), 0.8);
		float dBoxTower = opSubtraction(dBoxBase, dBoxHole);

		// Pyramid intersected with sphere
		float dPyramid = sdPyramid(p - float3(3, 0.0, -4), 1.5);
		float dPySphere = sdSphere(p - float3(3, 0.0, -4), 1.0);
		float dPyramidShape = opIntersection(dPyramid, dPySphere);

		// Cylinders forming a "cross"
		float dCyl1 = sdCappedCylinder(p, float3(0, -1, -6), float3(0, 1, -6), 0.3);
		float dCyl2 = sdCappedCylinder(p, float3(-1, 0, -6), float3(1, 0, -6), 0.3);
		float dCross = opUnion(dCyl1, dCyl2);

		// Combine all
		float scene = opUnion(dGround, opUnion(dCluster, opUnion(dBoxTower, opUnion(dPyramidShape, dCross))));

		return scene;
	}
}

// Better test scene generated by Claude
struct ClaudeBuildingScene : IFloatSdfScene {
	[Differentiable]
	static float sdf(float3 p) {
		float scene = 1e10;

		// Main building structure
		// Outer walls (large box with hollow interior)
		float outerWalls = sdBox(p, float3(12.0, 4.0, 10.0));
		float innerSpace = sdBox(p, float3(11.5, 3.8, 9.5));
		float walls = opSubtraction(innerSpace, outerWalls);

		// Floor (thin box)
		float floor = sdBox(p - float3(0.0, -3.9, 0.0), float3(12.0, 0.1, 10.0));

		// Ceiling with skylight cutout
		float ceiling = sdBox(p - float3(0.0, 3.9, 0.0), float3(12.0, 0.1, 10.0));
		float skylight1 = sdBox(p - float3(0.0, 4.0, 0.0), float3(2.0, 0.5, 4.0));
		ceiling = opSubtraction(skylight1, ceiling);

		// Support pillars (cylinders)
		float pillar1 = sdCappedCylinder(p - float3(-8.0, 0.0, -6.0), float3(0.0, -3.8, 0.0), float3(0.0, 3.8, 0.0), 0.3);
		float pillar2 = sdCappedCylinder(p - float3(8.0, 0.0, -6.0), float3(0.0, -3.8, 0.0), float3(0.0, 3.8, 0.0), 0.3);
		float pillar3 = sdCappedCylinder(p - float3(-8.0, 0.0, 6.0), float3(0.0, -3.8, 0.0), float3(0.0, 3.8, 0.0), 0.3);
		float pillar4 = sdCappedCylinder(p - float3(8.0, 0.0, 6.0), float3(0.0, -3.8, 0.0), float3(0.0, 3.8, 0.0), 0.3);

		// Central architectural feature - raised platform with stairs
		float platform = sdBox(p - float3(0.0, -3.0, 0.0), float3(3.0, 0.5, 3.0));

		// Stairs (series of boxes)
		float step1 = sdBox(p - float3(0.0, -3.6, -4.0), float3(1.5, 0.2, 0.5));
		float step2 = sdBox(p - float3(0.0, -3.4, -4.5), float3(1.5, 0.4, 0.5));
		float step3 = sdBox(p - float3(0.0, -3.2, -5.0), float3(1.5, 0.6, 0.5));

		// Display pedestals (boxes and cylinders)
		float pedestal1 = sdBox(p - float3(-5.0, -3.0, 0.0), float3(0.8, 0.8, 0.8));
		float pedestal2 = sdCappedCylinder(p - float3(5.0, -2.5, 0.0), float3(0.0, -1.3, 0.0), float3(0.0, 0.0, 0.0), 0.6);
		float pedestal3 = sdBox(p - float3(0.0, -3.0, 5.0), float3(0.6, 0.6, 0.6));

		// Art objects on pedestals (spheres and pyramids)
		float art1 = sdSphere(p - float3(-5.0, -1.5, 0.0), 0.5);
		float art2 = sdPyramid(p - float3(5.0, -1.5, 0.0), 0.8);
		float art3 = sdSphere(p - float3(0.0, -1.8, 5.0), 0.4);

		// Benches (elongated boxes with cutouts)
		float bench1Base = sdBox(p - float3(-3.0, -3.4, -5.0), float3(2.0, 0.3, 0.5));
		float bench1Cutout = sdBox(p - float3(-3.0, -3.4, -5.0), float3(1.7, 0.5, 0.3));
		float bench1 = opSubtraction(bench1Cutout, bench1Base);

		float bench2Base = sdBox(p - float3(3.0, -3.4, -5.0), float3(2.0, 0.3, 0.5));
		float bench2Cutout = sdBox(p - float3(3.0, -3.4, -5.0), float3(1.7, 0.5, 0.3));
		float bench2 = opSubtraction(bench2Cutout, bench2Base);

		// Doorway (subtract from wall)
		float doorway = sdBox(p - float3(0.0, -2.0, -9.8), float3(1.2, 2.0, 1.0));
		walls = opSubtraction(doorway, walls);

		// Windows (subtract from walls)
		float window1 = sdBox(p - float3(-11.8, 0.0, 0.0), float3(1.0, 1.5, 2.0));
		float window2 = sdBox(p - float3(11.8, 0.0, 0.0), float3(1.0, 1.5, 2.0));
		walls = opSubtraction(window1, walls);
		walls = opSubtraction(window2, walls);

		// Decorative wall elements (thin cylinders as columns)
		float decor1 = sdCappedCylinder(p - float3(-11.0, 0.0, -3.0), float3(0.0, -3.5, 0.0), float3(0.0, 3.5, 0.0), 0.15);
		float decor2 = sdCappedCylinder(p - float3(-11.0, 0.0, 3.0), float3(0.0, -3.5, 0.0), float3(0.0, 3.5, 0.0), 0.15);
		float decor3 = sdCappedCylinder(p - float3(11.0, 0.0, -3.0), float3(0.0, -3.5, 0.0), float3(0.0, 3.5, 0.0), 0.15);
		float decor4 = sdCappedCylinder(p - float3(11.0, 0.0, 3.0), float3(0.0, -3.5, 0.0), float3(0.0, 3.5, 0.0), 0.15);

		// Central sculpture (complex CSG)
		float sculptureBase =
			sdCappedCylinder(p - float3(0.0, -1.0, 0.0), float3(0.0, -1.5, 0.0), float3(0.0, 0.0, 0.0), 1.0);
		float sculptureSphere = sdSphere(p - float3(0.0, -0.5, 0.0), 0.8);
		float sculptureBox = sdBox(p - float3(0.0, -0.5, 0.0), float3(0.5, 0.5, 0.5));
		float sculpture = opIntersection(sculptureSphere, sculptureBox);
		sculpture = opUnion(sculpture, sculptureBase);

		// Assemble the scene
		scene = opUnion(walls, floor);
		scene = opUnion(scene, ceiling);
		scene = opUnion(scene, pillar1);
		scene = opUnion(scene, pillar2);
		scene = opUnion(scene, pillar3);
		scene = opUnion(scene, pillar4);
		scene = opUnion(scene, platform);
		scene = opUnion(scene, step1);
		scene = opUnion(scene, step2);
		scene = opUnion(scene, step3);
		scene = opUnion(scene, pedestal1);
		scene = opUnion(scene, pedestal2);
		scene = opUnion(scene, pedestal3);
		scene = opUnion(scene, art1);
		scene = opUnion(scene, art2);
		scene = opUnion(scene, art3);
		scene = opUnion(scene, bench1);
		scene = opUnion(scene, bench2);
		scene = opUnion(scene, sculpture);
		scene = opUnion(scene, decor1);
		scene = opUnion(scene, decor2);
		scene = opUnion(scene, decor3);
		scene = opUnion(scene, decor4);

		return scene;
	}
}

float readFloat(uint paramIndex) {
	return asfloat(sceneProgramData[0].params[paramIndex]);
}
float2 readFloat2(uint paramIndex) {
	return float2(
		asfloat(sceneProgramData[0].params[paramIndex]),
		asfloat(sceneProgramData[0].params[paramIndex + 1]),
	);
}
float3 readFloat3(uint paramIndex) {
	return float3(
		asfloat(sceneProgramData[0].params[paramIndex]),
		asfloat(sceneProgramData[0].params[paramIndex + 1]),
		asfloat(sceneProgramData[0].params[paramIndex + 2])
	);
}
void writeFloat(uint paramIndex, float value) {
	sceneProgramData[0].params[paramIndex] = asuint(value);
}
void writeFloat2(uint paramIndex, float2 value) {
	sceneProgramData[0].params[paramIndex] = asuint(value.x);
	sceneProgramData[0].params[paramIndex + 1] = asuint(value.y);
}
void writeFloat3(uint paramIndex, float3 value) {
	sceneProgramData[0].params[paramIndex] = asuint(value.x);
	sceneProgramData[0].params[paramIndex + 1] = asuint(value.y);
	sceneProgramData[0].params[paramIndex + 2] = asuint(value.z);
}

// Operations eval
void evalAddOp(SdfInstruction insn) {
	float d1; float d2;
	d1 = readFloat(insn.paramsIndex); d2 = readFloat(insn.paramsIndex + 1);
	float res = opUnion(d1, d2);
}
void evalSubOp(SdfInstruction insn) {
	float d1; float d2;
	d1 = readFloat(insn.paramsIndex); d2 = readFloat(insn.paramsIndex + 1);
	float res = opSubtraction(d1, d2);
}
void evalInterOp(SdfInstruction insn) {
	float d1; float d2;
	d1 = readFloat(insn.paramsIndex); d2 = readFloat(insn.paramsIndex + 1);
	float res = opIntersection(d1, d2);
}
void evalXorOp(SdfInstruction insn) {
	float d1; float d2;
	d1 = readFloat(insn.paramsIndex); d2 = readFloat(insn.paramsIndex + 1);
	float res = opXor(d1, d2);
}
void evalSmoothAddOp(SdfInstruction insn) {
	float d1; float d2; float k;
	d1 = readFloat(insn.paramsIndex); d2 = readFloat(insn.paramsIndex + 1);
	float res = opSmoothUnion(d1, d2, k);
}
void evalSmoothSubOp(SdfInstruction insn) {
	float d1; float d2; float k;
	d1 = readFloat(insn.paramsIndex); d2 = readFloat(insn.paramsIndex + 1);
	float res = opSmoothSubtraction(d1, d2, k);
}
void evalSmoothInterOp(SdfInstruction insn) {
	float d1; float d2; float k;
	d1 = readFloat(insn.paramsIndex); d2 = readFloat(insn.paramsIndex + 1);
	float res = opSmoothIntersection(d1, d2, k);
}

// Shapes eval
void evalSphere(SdfInstruction insn, float3 rayP) {
	float3 p; float r;
	p = readFloat3(insn.paramsIndex); r = readFloat(insn.paramsIndex + 3);
	float res = sdSphere(rayP - p, r);
	writeFloat(insn.outputIndex, res);
}
void evalBox(SdfInstruction insn, float3 rayP) {
	float3 p; float3 halfExtent;
	p = readFloat3(insn.paramsIndex); halfExtent = readFloat3(insn.paramsIndex + 3);
	float res = sdBox(rayP - p, halfExtent);
	writeFloat(insn.outputIndex, res);
}
void evalRoundBox(SdfInstruction insn, float3 rayP) {
	float3 p; float3 halfExtent; float r;
	p = readFloat3(insn.paramsIndex); halfExtent = readFloat3(insn.paramsIndex + 3); r = readFloat(insn.paramsIndex + 6);
	float res = sdRoundBox(rayP - p, halfExtent, r);
	writeFloat(insn.outputIndex, res);
}
void evalBoxFrame(SdfInstruction insn, float3 rayP) {
	float3 p; float3 b; float e;
	p = readFloat3(insn.paramsIndex); b = readFloat3(insn.paramsIndex + 3); e = readFloat(insn.paramsIndex + 6);
	float res = sdBoxFrame(rayP - p, b, e);
	writeFloat(insn.outputIndex, res);
}
void evalCone(SdfInstruction insn, float3 rayP) {
	float3 p; float2 c; float h;
	p = readFloat3(insn.paramsIndex); c = readFloat2(insn.paramsIndex + 3); h = readFloat(insn.paramsIndex + 5);
	float res = sdCone(rayP - p, c, h);
	writeFloat(insn.outputIndex, res);
}
void evalCappedCone(SdfInstruction insn, float3 rayP) {
	float3 p; float3 a; float3 b; float ra; float rb;
	p = readFloat3(insn.paramsIndex); a = readFloat3(insn.paramsIndex + 3); b = readFloat3(insn.paramsIndex + 6);
	ra = readFloat(insn.paramsIndex + 9); rb = readFloat(insn.paramsIndex + 10);
	float res = sdCappedCone(rayP - p, a, b, ra, rb);
	writeFloat(insn.outputIndex, res);
}
void evalHexPrism(SdfInstruction insn, float3 rayP) {
	float3 p; float2 h;
	p = readFloat3(insn.paramsIndex); h = readFloat2(insn.paramsIndex + 3);
	float res = sdHexPrism(rayP - p, h);
	writeFloat(insn.outputIndex, res);
}
void evalTriPrism(SdfInstruction insn, float3 rayP) {
	float3 p; float2 h;
	p = readFloat3(insn.paramsIndex); h = readFloat2(insn.paramsIndex + 3);
	float res = sdTriPrism(rayP - p, h);
	writeFloat(insn.outputIndex, res);
}
void evalCapsule(SdfInstruction insn, float3 rayP) {
	float3 p; float3 a; float3 b; float r;
	p = readFloat3(insn.paramsIndex); a = readFloat3(insn.paramsIndex + 3); b = readFloat3(insn.paramsIndex + 6);
	r = readFloat(insn.paramsIndex + 9);
	float res = sdCapsule(rayP - p, a, b, r);
	writeFloat(insn.outputIndex, res);
}
void evalCappedCylinder(SdfInstruction insn, float3 rayP) {
	float3 p; float3 a; float3 b; float r;
	p = readFloat3(insn.paramsIndex); a = readFloat3(insn.paramsIndex + 3); b = readFloat3(insn.paramsIndex + 6);
	r = readFloat(insn.paramsIndex + 9);
	float res = sdCappedCylinder(rayP - p, a, b, r);
	writeFloat(insn.outputIndex, res);
}
void evalRoundedCylinder(SdfInstruction insn, float3 rayP) {
	float3 p; float ra; float rb; float h;
	p = readFloat3(insn.paramsIndex); ra = readFloat(insn.paramsIndex + 3); rb = readFloat(insn.paramsIndex + 4);
	h = readFloat(insn.paramsIndex + 5);
	float res = sdRoundedCylinder(rayP - p, ra, rb, h);
	writeFloat(insn.outputIndex, res);
}
void evalCutSphere(SdfInstruction insn, float3 rayP) {
	float3 p; float r; float h;
	p = readFloat3(insn.paramsIndex); r = readFloat(insn.paramsIndex + 3); h = readFloat(insn.paramsIndex + 4);
	float res = sdCutSphere(rayP - p, r, h);
	writeFloat(insn.outputIndex, res);
}
void evalOctahedron(SdfInstruction insn, float3 rayP) {
	float3 p; float s;
	p = readFloat3(insn.paramsIndex); s = readFloat(insn.paramsIndex + 3);
	float res = sdOctahedron(rayP - p, s);
	writeFloat(insn.outputIndex, res);
}
void evalPyramid(SdfInstruction insn, float3 rayP) {
	float3 p; float h;
	p = readFloat3(insn.paramsIndex); h = readFloat(insn.paramsIndex + 3);
	float res = sdPyramid(rayP - p, h);
	writeFloat(insn.outputIndex, res);
}
void evalTriangle(SdfInstruction insn, float3 rayP) {
	float3 p; float3 a; float3 b; float3 c;
	p = readFloat3(insn.paramsIndex); a = readFloat3(insn.paramsIndex + 3); b = readFloat3(insn.paramsIndex + 6);
	c = readFloat(insn.paramsIndex + 9);
	float res = udTriangle(rayP - p, a, b, c);
	writeFloat(insn.outputIndex, res);
}
void evalQuad(SdfInstruction insn, float3 rayP) {
	float3 p; float3 a; float3 b; float3 c; float3 d;
	p = readFloat3(insn.paramsIndex); a = readFloat3(insn.paramsIndex + 3); b = readFloat3(insn.paramsIndex + 6);
	c = readFloat(insn.paramsIndex + 9); d = readFloat(insn.paramsIndex + 12);
	float res = udQuad(rayP - p, a, b, c, d);
	writeFloat(insn.outputIndex, res);
}


// TODO: Add passing the correct material through all the evaluations
struct SdfProgramScene : IFloatSdfScene {

	static float sdf(float3 p) {
		uint insnCount, stride; sceneProgram.GetDimensions(insnCount, stride);
		for (uint i = 0; i < insnCount; i++) {
			SdfInstruction insn = sceneProgram[i];
			switch (insn.kind) {
				case SdfInstructionKind.AddOp: evalAddOp(insn); break;
				case SdfInstructionKind.SubOp: evalSubOp(insn); break;
				case SdfInstructionKind.InterOp: evalInterOp(insn); break;
				case SdfInstructionKind.XorOp: evalXorOp(insn); break;
				case SdfInstructionKind.SmoothAddOp: evalSmoothAddOp(insn); break;
				case SdfInstructionKind.SmoothSubOp: evalSmoothSubOp(insn); break;
				case SdfInstructionKind.SmoothInterOp: evalSmoothInterOp(insn); break;
				case SdfInstructionKind.Sphere: evalSphere(insn, p); break;
				case SdfInstructionKind.Box: evalBox(insn, p); break;
				case SdfInstructionKind.RoundBox: evalRoundBox(insn, p); break;
				case SdfInstructionKind.BoxFrame: evalBoxFrame(insn, p); break;
				case SdfInstructionKind.Cone: evalCone(insn, p); break;
				case SdfInstructionKind.CappedCone: evalCappedCone(insn, p); break;
				case SdfInstructionKind.HexPrism: evalHexPrism(insn, p); break;
				case SdfInstructionKind.TriPrism: evalTriPrism(insn, p); break;
				case SdfInstructionKind.Capsule: evalCapsule(insn, p); break;
				case SdfInstructionKind.CappedCylinder: evalCappedCylinder(insn, p); break;
				case SdfInstructionKind.RoundedCylinder: evalRoundedCylinder(insn, p); break;
				case SdfInstructionKind.CutSphere: evalCutSphere(insn, p); break;
				case SdfInstructionKind.Octahedron: evalOctahedron(insn, p); break;
				case SdfInstructionKind.Pyramid: evalPyramid(insn, p); break;
				case SdfInstructionKind.Triangle: evalTriangle(insn, p); break;
				case SdfInstructionKind.Quad: evalQuad(insn, p); break;
			}
		}

		let lastInsn = sceneProgram[insnCount - 1];
		return readFloat(lastInsn.outputIndex);
	}

}

// Fancy numeric normal function from https://iquilezles.org/articles/normalsSDF/
float3 calcNormal<T>(T sceneFn, float3 p, float eps) where T : IFloatSdfScene {
  const float2 k = float2(1, -1);
  return normalize(k.xyy * sceneFn.sdf(p + k.xyy * eps) + k.yyx * sceneFn.sdf(p + k.yyx * eps) +
                   k.yxy * sceneFn.sdf(p + k.yxy * eps) + k.xxx * sceneFn.sdf(p + k.xxx * eps));
}

// Slang auto-diff based normal
float3 exactNormal<T>(T sceneFn, in float3 p) where T : IDifferentiableFloatSdfScene {
  float3 normal;
  for (uint axis = 0; axis < 3; axis++) {
    DifferentialPair<float3> dp =
      diffPair(float3(p.x, p.y, p.z), float3(axis == 0 ? 1.0 : 0.0, axis == 1 ? 1.0 : 0.0, axis == 2 ? 1.0 : 0.0));
    DifferentialPair<float> dpOut = fwd_diff(sceneFn.sdf)(dp);
    normal[axis] = dpOut.d;
  }

  return normalize(normal);
}

static const int maxSteps = 512;
Optional<float3> sphereTrace<T>(
	T sceneFn, float3 startPos, float3 rayDir, out float rayDist, out float distToClosest, out uint stepCount
) where T : IFloatSdfScene {
  const float baseHitEps = 1e-6; // How close to an object should the ray be for it to hit
	const float minHitEps = 1e-8; // This might be too small
	const float maxHitEps = 1e-2;
	const float maxEpsStepCountScaling = 5000;
  // TODO: Dynamic far clip distance based on sceneFn contents?
  const float farClipDist = 100.0;

  rayDist = 0;
	for (stepCount = 0; stepCount < maxSteps; stepCount++) {
    float3 pos = startPos + rayDir * rayDist;
    distToClosest = sceneFn.sdf(pos);
		// Dynamic ray hit epsilon. Scale by dist to keep ray from missing far away hits and
		// by step budget to prevent missing surfaces at grazing angles. 
		float stepCountScale = 1.0 + maxEpsStepCountScaling * pow(stepCount / float(maxSteps), 10); // On the GPU, pow might be heavy?
		float hitEps = clamp(baseHitEps * rayDist * stepCountScale, minHitEps, maxHitEps); 

    if (distToClosest < hitEps) {
      float3 hitPos = pos + rayDir * distToClosest;
			return hitPos;
    }

    rayDist += distToClosest;
    if (rayDist > farClipDist)
      break;
  }

	return none;
}

void renderScene<T>(T sceneFn, inout FragmentOutput output, float3 rayDirection) where T : IFloatSdfScene {
  // Lighting is hardcoded for now
  const float3 lightDirection = normalize(float3(-5.0, -5.0, -3.0));
	const float numericNormalMinEps = 8e-6;

	float rayDist, lastStepLen;
	uint stepCount;
	var hitOpt = sphereTrace(sceneFn, scene.camPos, rayDirection, rayDist, lastStepLen, stepCount);
	if (hitOpt.hasValue) {
		let hitPos = hitOpt.value;
		// NOTE: Using doubles to calculate normals could make shimmering normals at edges much rarer
		float3 safePos = hitPos - (lastStepLen * rayDirection);
		float3 worldNormalHit = calcNormal(sceneFn, hitPos, max(numericNormalMinEps, 1e-9 * rayDist));
		float3 worldNormalSafe = calcNormal(sceneFn, safePos, max(numericNormalMinEps, 1e-9 * rayDist));
		float3 worldNormal = dot(worldNormalHit, -scene.camForward) > dot(worldNormalSafe, -scene.camForward)
														? worldNormalHit
														: worldNormalSafe;

		float3 diffuseColor = max(dot(worldNormal, -lightDirection), 0.0) * scene.hitColor;

		switch(debugOpt.mode) {
			case RenderMode.ShadedScene:
				output.color = float4(diffuseColor, 1.0);
				return;
			case RenderMode.UnlitScene:
				output.color = float4(scene.hitColor, 1.0);
				return;
			case RenderMode.DebugNormals:
				output.color = float4(worldNormal, 1.0);
				return;
			case RenderMode.DebugStepCounts:
				float normalizedStepCount = saturate((float)stepCount / (maxSteps / 2));
				float3 stepsGradientColor = lerp(float3(0, 1, 0), float3(1, 0, 0), normalizedStepCount);
				output.color = float4(stepsGradientColor, 1);
				return;
		}
	}

  // Set to background color to prevent weird colors for pixels with no hits
  output.color = float4(scene.bgColor, 1.0);
}

// Check the fragment shader code to make sure it matches a basic raytraced camera setup. This was done very quickly to
// see if a fullscreen shader works.
[shader("fragment")]
FragmentOutput fragmentMain(VertexOutput input) {
  FragmentOutput output = (FragmentOutput)0;

  float2 uvNdc = input.fragUv * 2.0 - 1.0;
  uvNdc.x *= scene.aspect;
  float z = 1.0 / tan(radians(scene.fov) * 0.5); // Image plane depth
  float3 rayDirection = normalize(scene.camForward * z + scene.camRight * uvNdc.x + scene.camUp * uvNdc.y);

	renderScene(SdfProgramScene(), output, rayDirection);
	let firstInsn = sceneProgram[0];
	let firstParamI = firstInsn.paramsIndex;
	let boxPos = readFloat3(firstParamI);
	let boxSize = readFloat3(firstParamI + 3);
	let secondInsn = sceneProgram[1];
	let thirdInsn = sceneProgram[2];
	if (
		firstInsn.kind == SdfInstructionKind.Box && firstInsn.paramsIndex == 0 && firstInsn.outputIndex == 32767 && firstInsn.paramsSize == 6
	) {
		output.color = float4(0, 1, 0, 1);
	}

  // Ray direction visualization
  // output.color = float4(0.5 * rayDir + 0.5, 1.0);
  return output;
}
